# ------------------------------------------
.idea/
_ReSharper*/
*.DotSettings.user
*.sln.iml

# ------------------------------------------
# VS Code
# ------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ------------------------------------------
# Build Logs
